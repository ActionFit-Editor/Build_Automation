  _packageId: com.actionfit.buildautomation
  _displayName: Build Automation
  _repoName: Build_Automation
  _owner: "\uC1A1\uC81C\uC6B0"
  _status: verified
  _description: BuildCommit request creation, Git tag based CI triggers, GitHub Actions
    workflow templates, and macOS self-hosted mobile build guidance for ActionFit
    Unity projects.
  _releaseNote: '- BuildCommit now serializes Android alias, keystore password, and
    alias password from BuildSetting into the request.

    - RunnerSetup keeps keystore
    files, Google Play, App Store Connect, and keychain credentials on the Mac runner,
    with Android password env values as fallback.

    - AutoBuild uses the BuildSetting
    default SO auto-create flow and remains under the Tools/ActionFit/BuildSetting
    menu group.

    - Build Automation depends on com.actionfit.buildsetting@1.1.2.'
  _dependenciesOverride: com.actionfit.buildsetting@1.1.2
